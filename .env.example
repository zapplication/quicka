# ─────────────────────────────────────────────────────────────────
# PayFast — sandbox values for local development
# Get sandbox credentials from https://sandbox.payfast.co.za
# ─────────────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn
PAYFAST_SANDBOX=true

# Public site URL — used for return_url, cancel_url, notify_url construction.
# In local dev with ngrok, set this to your ngrok URL so PayFast's IPN can
# reach your local machine.
NEXT_PUBLIC_SITE_URL=https://quicka.website

# ─────────────────────────────────────────────────────────────────
# Absolute Hosting — domain registrar
# Sign up at https://www.zadomains.net (free reseller account, no setup fees).
# Add credentials in Vercel → Project Settings → Environment Variables.
# Never paste the password into chat or commit it to the repo.
# ─────────────────────────────────────────────────────────────────
ABSOLUTE_HOSTING_USERNAME=DUTO5772
ABSOLUTE_HOSTING_PASSWORD=
ABSOLUTE_HOSTING_API_URL=https://www.zadomains.net/api/API_GENERAL.asmx

# ZACR WHOIS server (used for the domain availability check, since
# Absolute Hosting's API has no Domain_Check method). These defaults are fine
# for production unless ZACR ever changes their public WHOIS endpoint.
ZACR_WHOIS_HOST=whois.registry.net.za
ZACR_WHOIS_PORT=43

# ─────────────────────────────────────────────────────────────────
# Internal API secret — guards /api/domains/register so it can ONLY be
# called by our PayFast webhook, never by a user's browser.
# Generate a fresh value with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=

# ─────────────────────────────────────────────────────────────────
# Production values (set these in Vercel / Cloudflare env, NOT here)
# ─────────────────────────────────────────────────────────────────
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
# PAYFAST_SANDBOX=false
# NEXT_PUBLIC_SITE_URL=https://quicka.website
# ABSOLUTE_HOSTING_USERNAME=
# ABSOLUTE_HOSTING_PASSWORD=
# INTERNAL_API_SECRET=
